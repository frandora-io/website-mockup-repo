# Reservation system — set these in Vercel (Project Settings → Environment Variables)

# Resend (https://resend.com) — used for owner notification + guest confirmation
RESEND_API_KEY=
# Must be a verified sender on your Resend domain, e.g. reservations@ilnonnonyc.com
RESEND_FROM_EMAIL=

# Twilio (https://www.twilio.com) — used for SMS to the owner
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number you purchased, in E.164 format (e.g. +17185550123)
TWILIO_FROM_NUMBER=

# Where reservation notifications go
OWNER_EMAIL=
# Owner cell in E.164 format (e.g. +17185550123)
OWNER_PHONE=
